@page
@model SDJDPAssetPortalV2.Pages.AssetsModel

@{
    ViewData["Title"] = "Asset Management";
}

<style>
    body {
        font-family: Segoe UI;
        background-color: #f4f6f9;
    }

    .topbar {
        background-color: #1f4e79;
        color: white;
        padding: 15px;
        margin-bottom: 20px;
        border-radius: 8px;
    }

        .topbar h1 {
            margin: 0;
        }

    .nav-links {
        margin-top: 10px;
    }

        .nav-links a {
            color: white;
            margin-right: 20px;
            text-decoration: none;
            font-weight: bold;
        }

    .card {
        background: white;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 20px;
        box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    }

    .form-row {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .form-group {
        display: flex;
        flex-direction: column;
    }

    input {
        padding: 10px;
        width: 200px;
        border-radius: 6px;
        border: 1px solid #ccc;
    }

    button {
        padding: 10px 18px;
        border: none;
        border-radius: 6px;
        cursor: pointer;
        color: white;
        font-weight: bold;
    }

    .add-btn {
        background-color: #28a745;
    }

    .update-btn {
        background-color: #007bff;
    }

    .search-btn {
        background-color: #6f42c1;
    }

    .delete-btn {
        background-color: #dc3545;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #1f4e79;
        color: white;
        padding: 12px;
    }

    td {
        padding: 10px;
        border-bottom: 1px solid #ddd;
    }
</style>

<div class="topbar">

    <h1>SDJDP Asset Management Portal</h1>

    <div class="nav-links">
        <a href="/Assets">Home</a>
        <a href="/About">About</a>
        <a href="/Contact">Contact</a>
        <a href="/">Logout</a>
    </div>

</div>

<div class="card">

    <h2>Search Asset</h2>

    <form method="post" asp-page-handler="Search">

        <div class="form-row">

            <div class="form-group">
                <input asp-for="SearchText" placeholder="Search assets..." />
            </div>

            <button type="submit" class="search-btn">Search</button>

        </div>

    </form>

</div>

<div class="card">

    <h2>Add New Asset</h2>

    <form method="post" asp-page-handler="Add">

        <div class="form-row">

            <div class="form-group">
                <label>Asset ID</label>
                <input asp-for="NewAsset.AssetID" />
            </div>

            <div class="form-group">
                <label>Asset Type</label>
                <input asp-for="NewAsset.AssetType" />
            </div>

            <div class="form-group">
                <label>Serial Number</label>
                <input asp-for="NewAsset.SerialNumber" />
            </div>

            <div class="form-group">
                <label>Department</label>
                <input asp-for="NewAsset.Department" />
            </div>

            <div class="form-group">
                <label>Status</label>
                <input asp-for="NewAsset.Status" />
            </div>

            <button type="submit" class="add-btn">Add Asset</button>

        </div>

    </form>

</div>

<div class="card">

    <h2>Update Asset</h2>

    <form method="post" asp-page-handler="Update">

        <div class="form-row">

            <div class="form-group">
                <label>Asset ID</label>
                <input asp-for="UpdateAssetData.AssetID" />
            </div>

            <div class="form-group">
                <label>Asset Type</label>
                <input asp-for="UpdateAssetData.AssetType" />
            </div>

            <div class="form-group">
                <label>Serial Number</label>
                <input asp-for="UpdateAssetData.SerialNumber" />
            </div>

            <div class="form-group">
                <label>Department</label>
                <input asp-for="UpdateAssetData.Department" />
            </div>

            <div class="form-group">
                <label>Status</label>
                <input asp-for="UpdateAssetData.Status" />
            </div>

            <button type="submit" class="update-btn">Update Asset</button>

        </div>

    </form>

</div>

<div class="card">

    <h2>Asset Records</h2>

    <table>

        <tr>
            <th>Asset ID</th>
            <th>Asset Type</th>
            <th>Serial Number</th>
            <th>Department</th>
            <th>Status</th>
            <th>Delete</th>
        </tr>

        @foreach (var asset in Model.Assets)
        {
            <tr>
                <td>@asset.AssetID</td>
                <td>@asset.AssetType</td>
                <td>@asset.SerialNumber</td>
                <td>@asset.Department</td>
                <td>@asset.Status</td>

                <td>
                    <form method="post" asp-page-handler="Delete">

                        <input type="hidden" name="assetID" value="@asset.AssetID" />

                        <button type="submit" class="delete-btn">
                            Delete
                        </button>

                    </form>
                </td>
            </tr>
        }

    </table>

</div>